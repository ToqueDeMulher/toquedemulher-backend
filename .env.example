# Aplicação
APP_NAME="O Toque de Mulher"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY=sua_chave_secreta_aqui_minimo_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Banco de Dados
DATABASE_URL=postgresql://usuario:senha@localhost:5432/toquedemulher

# Redis (para cache e filas de tarefas)
REDIS_URL=redis://localhost:6379/0

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_mercadopago
MERCADOPAGO_PUBLIC_KEY=sua_public_key_mercadopago
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret

# PagBank (PagSeguro)
PAGBANK_TOKEN=seu_token_pagbank
PAGBANK_EMAIL=seu_email_pagbank
PAGBANK_SANDBOX=True

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app
EMAIL_FROM=noreply@toquedemulher.com.br
EMAIL_FROM_NAME="O Toque de Mulher"

# Upload de Arquivos
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL (para links em emails)
FRONTEND_URL=http://localhost:3000
